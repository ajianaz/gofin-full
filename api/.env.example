# Gofin API Configuration
# Copy this file to .env and fill in the values

# ============================================
# Application Core
# ============================================
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
TZ=UTC

# ============================================
# HTTP Server
# ============================================
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# ============================================
# Database (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=firefly_secret
DB_SSL_MODE=prefer
DB_SCHEMA=public
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME=300

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================
# Keycloak
# ============================================
KEYCLOAK_URL=http://localhost:8088
KEYCLOAK_REALM=firefly
KEYCLOAK_CLIENT_ID=firefly-go-api
KEYCLOAK_CLIENT_SECRET=

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================
# Authentication
# ============================================
AUTH_PROVIDER=local
AUTH_JWT_SECRET=change-me-in-production-32chars!
AUTH_JWT_EXPIRY_MINUTES=60
AUTH_REFRESH_EXPIRY_DAYS=30
AUTH_ALLOW_REGISTRATION=false
STATIC_CRON_TOKEN=PLEASE_REPLACE_WITH_32_CHAR_CODE

# ============================================
# OAuth - Google
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# OAuth - GitHub
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# Security
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=10485760
CORS_ALLOWED_ORIGINS=http://localhost:5173
ALLOW_2FA_BYPASS=false
DISABLE_PROMETHEUS=false

# ============================================
# Feature Flags
# ============================================
FEATURE_EXPORT=true
FEATURE_WEBHOOKS=true
FEATURE_HANDLE_DEBTS=true
FEATURE_EXPRESSION_ENGINE=true
FEATURE_RUNNING_BALANCE=true

# ============================================
# Business Logic
# ============================================
MAX_UPLOAD_SIZE=1073741824
ALLOW_WEBHOOKS=false
WEBHOOK_MAX_ATTEMPTS=3
ENABLE_EXTERNAL_RATES=false
ENABLE_EXCHANGE_RATES=false
